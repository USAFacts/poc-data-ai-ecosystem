# Analysis Layer Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API key for LLM-powered metadata suggestions
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# MinIO connection (defaults shown - override if needed)
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=gov-data-lake
# MINIO_SECURE=false

# Metadata catalog bucket (defaults to metadata-catalog)
# METADATA_CATALOG_BUCKET=metadata-catalog
