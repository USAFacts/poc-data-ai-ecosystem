# Database Configuration
# PostgreSQL (recommended)
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/pipeline
# Legacy SQLite fallback (if DATABASE_URL is not set)
# DATABASE_PATH=./pipeline.db

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gov-data-lake
MINIO_SECURE=false

# API Keys (add as needed for specific agencies)
# CENSUS_API_KEY=your_census_api_key_here

# Pipeline Configuration
MANIFESTS_PATH=./manifests
LOG_LEVEL=INFO

# Logging — persist pipeline logs to the database (requires DATABASE_URL)
PIPELINE_LOG_DB=true
# PIPELINE_LOG_LEVEL=INFO
# PIPELINE_LOG_DIR=./logs

# Claude Vision (PDF/image parsing via Azure AI Foundry)
CLAUDE_VISION_KEY=your_claude_vision_key_here
CLAUDE_VISION_URL=https://usafacts-poc-resource.services.ai.azure.com/anthropic
# CLAUDE_VISION_MODEL=claude-sonnet-4-5

# Anthropic credentials (via Azure AI Foundry)
# Model Specific API Key: https://ai.azure.com/nextgen/r/gDzRMNvVTeOPujpACrdM8A,usafacts-poc,,usafacts-poc-resource,usafacts-poc/build/models/deployments/claude-haiku-4-5/details
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://usafacts-poc-resource.services.ai.azure.com/anthropic

# Weaviate Configuration (sync step)
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8085
WEAVIATE_GRPC_PORT=50051

# Neo4j Configuration (sync step)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pipeline123
