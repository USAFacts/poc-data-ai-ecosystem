# Database Configuration
# PostgreSQL (recommended)
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/pipeline
# Legacy SQLite fallback (if DATABASE_URL is not set)
# DATABASE_PATH=../ingestion-processing/pipeline.db

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gov-data-lake
MINIO_SECURE=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Anthropic API Configuration (for Data Assistant)
# Using Azure AI Foundry endpoint for Claude
# Model Specific API Key: https://ai.azure.com/nextgen/r/gDzRMNvVTeOPujpACrdM8A,usafacts-poc,,usafacts-poc-resource,usafacts-poc/build/models/deployments/claude-sonnet-4-5/details
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://usafacts-poc-resource.services.ai.azure.com/anthropic

# Weaviate Configuration (hybrid search backend)
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8085
WEAVIATE_GRPC_PORT=50051

# Neo4j Configuration (knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pipeline123

# Search & Graph Configuration
GRAPH_ENABLED=true

# Firecrawl API Key (for web search on .gov and usafacts.org)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Note: Semantic search uses sentence-transformers (all-MiniLM-L6-v2) locally
# No external API key required for embeddings

# Census API Key (for demographic data enrichment)
CENSUS_API_KEY=your_key_here

# Congress.gov API Key (for legislative data enrichment)
CONGRESS_API_KEY=your_key 